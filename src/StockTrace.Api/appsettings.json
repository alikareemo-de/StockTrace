{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=StockTrace;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Database": {
    "InitializeOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Jwt": {
    "Issuer": "StockTrace",
    "Audience": "StockTrace.TestingUI",
    "SigningKey": "STJTK-0123456789-ABCDEFGHIJKLMNOPQRSTUVWXYZ-abcdefghijk",
    "ExpirationMinutes": 120
  },
  "Authentication": {
    "TestUsers": {
      "Users": [
        {
          "Username": "admin",
          "Password": "Admin@12345",
          "DisplayName": "System Administrator",
          "Role": "Admin",
          "Permissions": [
            "MasterData.Read",
            "MasterData.ManageThresholds",
            "Inventory.Read",
            "PurchaseReceipts.Read",
            "PurchaseReceipts.Create",
            "Sales.Read",
            "Sales.Create",
            "StockTransfers.Read",
            "StockTransfers.Create",
            "Reports.Read",
            "Reports.Export",
            "Realtime.Read"
          ],
          "Description": "Full access to every module, including threshold management and report export."
        },
        {
          "Username": "warehouse.manager",
          "Password": "Warehouse@12345",
          "DisplayName": "Warehouse Manager",
          "Role": "WarehouseManager",
          "Permissions": [
            "MasterData.Read",
            "MasterData.ManageThresholds",
            "Inventory.Read",
            "PurchaseReceipts.Read",
            "PurchaseReceipts.Create",
            "StockTransfers.Read",
            "StockTransfers.Create",
            "Realtime.Read"
          ],
          "Description": "Can receive stock, transfer stock, configure low-stock thresholds, and monitor inventory."
        },
        {
          "Username": "sales.user",
          "Password": "Sales@12345",
          "DisplayName": "Sales User",
          "Role": "SalesUser",
          "Permissions": [
            "MasterData.Read",
            "Inventory.Read",
            "Sales.Read",
            "Sales.Create",
            "Realtime.Read"
          ],
          "Description": "Can view inventory and create/read sales, but cannot receive or transfer stock."
        },
        {
          "Username": "reporter",
          "Password": "Reporter@12345",
          "DisplayName": "Reports User",
          "Role": "Reporter",
          "Permissions": [
            "MasterData.Read",
            "Inventory.Read",
            "Reports.Read",
            "Reports.Export",
            "Realtime.Read"
          ],
          "Description": "Can view master data, inventory, reports, and export reports to Excel."
        },
        {
          "Username": "inventory.viewer",
          "Password": "Viewer@12345",
          "DisplayName": "Inventory Viewer",
          "Role": "InventoryViewer",
          "Permissions": [
            "MasterData.Read",
            "Inventory.Read",
            "Realtime.Read"
          ],
          "Description": "Read-only access to master data and inventory availability."
        }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
